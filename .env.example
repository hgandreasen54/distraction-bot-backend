# Distraction Bot Backend — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# Deliver live values to the orchestrator (Heath → Cowork session) before Phase 4 ships.

# Stripe restricted secret key (refunds:write + charges:read)
STRIPE_SECRET_KEY=sk_test_PLACEHOLDER

# RevenueCat server secret key
REVENUECAT_SECRET_KEY=PLACEHOLDER

# RevenueCat webhook signing secret (from RC dashboard → Webhooks)
REVENUECAT_WEBHOOK_SECRET=PLACEHOLDER

# JWT signing secret — min 32 bytes random string
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=PLACEHOLDER

# Server port (Railway sets this automatically)
PORT=3000
